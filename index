<pre><code class="block"><span class="kw">import</span> java.util.Scanner;

<span class="kw">public class</span> <span class="ty">PrintElements</span>
{
    <span class="kw">public static void</span> <span class="nm">printElements</span>(<span class="ty">int</span>[] ar)
    {
