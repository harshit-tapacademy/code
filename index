<script>
function flash(btn){
  const t = btn.textContent;
  btn.textContent='Copied'; btn.classList.add('done');
  setTimeout(()=>{btn.textContent=t; btn.classList.remove('done')},1400);
}
function cp(btn){
  const code = btn.closest('.code').querySelector('code.block').innerText;
  if(navigator.clipboard && window.isSecureContext){
    navigator.clipboard.writeText(code).then(()=>flash(btn)).catch(()=>legacy(code,btn));
  } else {
    legacy(code,btn);
  }
}
function legacy(text,btn){
  const ta=document.createElement('textarea');
  ta.value=text; ta.setAttribute('readonly','');
  ta.style.cssText='position:absolute;left:-9999px;top:0';
  document.body.appendChild(ta);
  ta.select(); ta.setSelectionRange(0,ta.value.length);
  try{ document.execCommand('copy'); flash(btn); }catch(e){}
  document.body.removeChild(ta);
}
</script>
