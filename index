<pre><code class="block"><span class="kw">import</span> java.util.Scanner;

<span class="kw">public class</span> <span class="ty">PrintOccurrence</span>
{
    <span class="kw">public static void</span> <span class="nm">printOccurrence</span>(<span class="ty">int</span>[] ar)
