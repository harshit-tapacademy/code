<!-- 5.5 LARGEST REPEATING -->
<section class="prog">
  <h2><span class="tag">5·5</span> Largest repeating element</h2>
  <div class="body">

    <div class="q"><b>Q.</b> Print the largest value that repeats. e.g. <span class="arr">2 3 3 4 5 7 7 8 9 10</span> → <b>7</b>.</div>

    <h3>Idea — walk from the right</h3>
    <ul>
      <li>Sorted ascending → big values live on the right. To find the largest repeat, <b>start from the end</b> and move left; the first adjacent-equal pair you hit is the answer.</li>
      <li>(Silk Board / Banashankari: start from the stop nearest what you're looking for.)</li>
    </ul>

    <div class="code">
      <div class="bar"><span>LargestRepeating.java</span><button onclick="cp(this)">Copy</button></div>
<pre><code class="block"><span class="kw">import</span> java.util.Scanner;

<span class="kw">public class</span> <span class="ty">LargestRepeating</span>
{
    <span class="kw">public static</span> <span class="ty">int</span> <span class="nm">largestRepeating</span>(<span class="ty">int</span>[] ar)
    {
        <span class="kw">for</span> (<span class="ty">int</span> i = ar.length - <span class="st">2</span>; i &gt;= <span class="st">0</span>; i--)
        {
            <span class="kw">if</span> (ar[i] == ar[i + <span class="st">1</span>])
            {
                <span class="kw">return</span> ar[i];
            }
        }

        <span class="kw">return</span> -<span class="st">1</span>;   <span class="cm">// no repeating element</span>
    }

    <span class="kw">public static void</span> <span class="nm">main</span>(<span class="ty">String</span>[] args)
    {
